"""Environment configuration template."""

# Google AI Configuration (Gemini 2.5 Flash Lite)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI Configuration (optional, only needed when using openai: models)
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Tracing
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=loomis-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
ENABLE_TRACING=true

# Existing API Configuration
EXISTING_API_BASE_URL=http://localhost:8000
EXISTING_API_TIMEOUT=30
EXISTING_API_MAX_RETRIES=3

# Model Configuration
MODEL_ID=google:gemini-2.5-flash-lite
MODEL_TEMPERATURE=0.1
MODEL_MAX_TOKENS=1024

# LangGraph native persistence (managed by LangGraph API server)
POSTGRES_URI=postgresql://devuser:devpass123@localhost:5433/devdb

# Local Data
SEED_DEMO_DATA=false

# HITL Configuration
REQUIRE_APPROVAL_ON=create_shipment,file_complaint

# Observability
LOG_LEVEL=INFO

# Application Configuration
SERVICE_NAME=brain-service-assistant
SERVICE_PORT=8001
SERVICE_HOST=0.0.0.0
